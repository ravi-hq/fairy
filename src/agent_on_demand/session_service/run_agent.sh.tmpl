#!/bin/bash
# Runtime dispatcher generated by session_service.dispatcher.render_dispatcher_script.
#
# Contract with Django (session_service):
#   - This script is written to /run-agent.sh during provision_session and never
#     re-uploaded. All setup (packages, clone, user setup_script, MCP config,
#     skills) has already run on the Sprite by the time this script first
#     executes — so the script does no setup of its own.
#   - /tmp/aod-env holds the runtime API key plus any Environment.env_vars and
#     AOD_SESSION_ID. The script sources it to expose those values to the
#     runtime CLI without baking them into the script body.
#   - Per-turn: Django invokes `bash /run-agent.sh <mode>` where <mode> is
#     "run" on turn 1 and "continue" on subsequent turns, and pipes the prompt
#     bytes to stdin (via the Sprites WS stdin frame). The dispatcher slurps
#     stdin into $PROMPT before exec'ing the runtime CLI.
#
# Placeholders like @@TOKEN@@ are substituted by render_dispatcher_script.
# The raw template is not standalone bash; the rendered output is.
set -Eeuo pipefail

__aod_on_err() {
    echo "AOD_STAGE_FAILED: exit=$1 line=$2 command=$3" >&2
}
trap '__aod_on_err $? ${LINENO} "${BASH_COMMAND}"' ERR

set -a
# shellcheck disable=SC1091
source /tmp/aod-env
set +a

MODE="${1:-run}"
PROMPT=$(cat)
export PROMPT

cd /home/sprite

case "$MODE" in
    run)      exec @@RUN_CMD@@ ;;
    continue) exec @@CONTINUE_CMD@@ ;;
    *)        echo "unknown mode: $MODE" >&2; exit 2 ;;
esac
