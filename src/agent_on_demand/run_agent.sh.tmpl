#!/bin/bash
# Wrapper script generated by agent_on_demand.sprites_exec.build_wrapper_script.
#
# Contract with Django (session_service):
#   - Django writes this file to /run-agent.sh on the Sprite once, at
#     session-create time. It is never re-uploaded.
#   - Before every invocation, Django writes the per-turn prompt to
#     {PROMPT_FILE_PATH}. The script reads the prompt from there.
#   - Django invokes `bash /run-agent.sh <mode>` where mode is "run" on
#     turn 1 and "continue" on subsequent turns.
#   - On any failure, the script exits non-zero. The last stderr line before
#     exit is an AOD_STAGE_FAILED marker identifying the failing command.
#
# Placeholders like @@TOKEN@@ are substituted by build_wrapper_script.
# The raw template is not standalone bash; the rendered output is.
set -Eeuo pipefail

__aod_on_err() {
    echo "AOD_STAGE_FAILED: exit=$1 line=$2 command=$3" >&2
}
trap '__aod_on_err $? ${LINENO} "${BASH_COMMAND}"' ERR

__aod_cleanup() {
    rm -f /tmp/.git-credentials 2>/dev/null || true
    git config --global --unset credential.helper 2>/dev/null || true
}
trap __aod_cleanup EXIT

# Baked at session-create time
@@API_KEY_EXPORT@@
@@SESSION_ID_EXPORT@@
@@ENV_VARS_BLOCK@@

MODE="${1:-run}"
if [ ! -f @@PROMPT_FILE_PATH@@ ]; then
    echo "missing prompt file: @@PROMPT_FILE_PATH_RAW@@" >&2
    exit 2
fi
PROMPT=$(cat @@PROMPT_FILE_PATH@@)
export PROMPT

cd /home/sprite
mkdir -p .gemini

# One-time setup, gated on a sentinel so it's safe across modes and retries.
if [ ! -f @@INIT_SENTINEL_PATH@@ ]; then
    if [ ! -d .git ]; then
        git init -q
        git add -A 2>/dev/null || true
        git commit -q -m "init" --allow-empty 2>/dev/null || true
    fi
@@FIRST_RUN_BODY@@
    touch @@INIT_SENTINEL_PATH@@
fi

@@MCP_SECTION@@

@@SKILLS_SECTION@@

case "$MODE" in
    run)      exec @@RUN_CMD@@ ;;
    continue) exec @@CONTINUE_CMD@@ ;;
    *)        echo "unknown mode: $MODE" >&2; exit 2 ;;
esac
