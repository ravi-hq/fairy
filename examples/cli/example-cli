#!/usr/bin/env python3
"""example-cli — a minimal alias-ready CLI over Agent on Demand.

A drop-in replacement for `claude -p "<prompt>"` that runs the agent inside a
fresh Sprite sandbox with a pinned model, system prompt, tool set, and repo
list. Fork this file, edit the three config blocks below, drop it on your
PATH, and alias it.

    alias agent=/path/to/example-cli
    agent "work on the latest open issue in ravi-hq/fairy"

Requires: Python 3.11+, AOD_URL, AOD_TOKEN.
"""

from __future__ import annotations

import json
import os
import sys
from urllib.error import HTTPError, URLError
from urllib.request import Request, urlopen

# -------- configure me ------------------------------------------------------

AGENT = {
    "name": "example-cli",
    "model": "claude-sonnet-4-6",
    "runtime": "claude",
    "system": (
        "You are a senior engineer working inside a Sprite sandbox. "
        "Investigate thoroughly before editing. Keep changes minimal and "
        "focused on the task you were given."
    ),
}

ENVIRONMENT = {
    "name": "example-cli",
    "packages": {"apt": ["jq", "ripgrep"]},
    "networking": {"type": "unrestricted"},
}

REPOS = [
    "https://github.com/ravi-hq/fairy",
]

TIMEOUT = 1200

# ---------------------------------------------------------------------------


def _env(name: str, default: str | None = None) -> str:
    val = os.environ.get(name, default)
    if val is None:
        sys.exit(f"{name} must be set")
    return val


BASE = _env("AOD_URL", "http://localhost:8777").rstrip("/")
AUTH = {"Authorization": f"Bearer {_env('AOD_TOKEN')}"}


def api(method: str, path: str, body: dict | None = None) -> dict:
    headers = dict(AUTH)
    data = None
    if body is not None:
        headers["Content-Type"] = "application/json"
        data = json.dumps(body).encode()
    req = Request(f"{BASE}{path}", method=method, headers=headers, data=data)
    try:
        with urlopen(req) as resp:
            return json.loads(resp.read())
    except HTTPError as e:
        sys.exit(f"{method} {path} -> {e.code}: {e.read().decode(errors='replace')}")
    except URLError as e:
        sys.exit(f"{method} {path}: {e.reason}")


def ensure(resource: str, name: str, create_payload: dict) -> str:
    for item in api("GET", f"/{resource}")["data"]:
        if item["name"] == name:
            return item["id"]
    return api("POST", f"/{resource}", create_payload)["id"]


def stream(session_id: str) -> int:
    url = f"{BASE}/sessions/{session_id}/stream"
    req = Request(url, headers={**AUTH, "Accept": "text/event-stream"})
    try:
        resp = urlopen(req)
    except HTTPError as e:
        sys.exit(f"stream {session_id} -> {e.code}: {e.read().decode(errors='replace')}")
    except URLError as e:
        sys.exit(f"stream {session_id}: {e.reason}")

    with resp:
        for raw in resp:
            line = raw.decode("utf-8", errors="replace").rstrip("\r\n")
            if not line.startswith("data: "):
                continue
            event = json.loads(line[6:])
            kind = event.get("type")
            if kind == "output":
                out = sys.stdout if event.get("stream") == "stdout" else sys.stderr
                out.write(event.get("data", ""))
                out.flush()
            elif kind == "exit":
                return int(event.get("code") or 0)
            elif kind in ("error", "terminated", "stale"):
                print(f"\n[{kind}] {event.get('message', '')}", file=sys.stderr)
                return 1
    return 1


def main() -> int:
    if len(sys.argv) < 2:
        sys.exit(f"usage: {sys.argv[0]} '<prompt>'")
    prompt = " ".join(sys.argv[1:])

    env_id = ensure("environments", ENVIRONMENT["name"], ENVIRONMENT)
    agent_id = ensure("agents", AGENT["name"], {**AGENT, "environment_id": env_id})

    session = api(
        "POST",
        "/sessions",
        {
            "agent_id": agent_id,
            "prompt": prompt,
            "timeout": TIMEOUT,
            "resources": [{"type": "github_repository", "url": url} for url in REPOS],
        },
    )
    print(f"# session {session['id']}", file=sys.stderr)
    return stream(session["id"])


if __name__ == "__main__":
    sys.exit(main())
